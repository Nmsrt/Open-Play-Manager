# Client-side Supabase config. These are the ONLY env vars the app needs.
# Both are safe to ship to the browser; security is enforced by RLS policies.
# NEVER put the service role key here or anywhere in this repo.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Email of the single shared admin account behind the staff password login.
# Not a secret — the password is what gates access. Must match the one
# Supabase Auth account created per README step 3.
VITE_ADMIN_EMAIL=staff@openplay.local
